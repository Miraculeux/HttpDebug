<UserControl x:Class="HttpDebug.Views.SidebarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:m="clr-namespace:HttpDebug.Models"
             xmlns:views="clr-namespace:HttpDebug.Views"
             Background="{StaticResource Surface900}">
    <DockPanel LastChildFill="True">

        <!-- Tab switcher -->
        <Grid DockPanel.Dock="Top" Margin="8,8,8,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button x:Name="CollectionsTabBtn" Grid.Column="0" Style="{StaticResource SidebarTabButton}"
                    Click="ShowCollections_Click" Foreground="{StaticResource Accent}">
                <TextBlock Text="Collections" />
            </Button>
            <Button x:Name="HistoryTabBtn" Grid.Column="1" Style="{StaticResource SidebarTabButton}"
                    Click="ShowHistory_Click">
                <TextBlock Text="History" />
            </Button>
        </Grid>

        <Border DockPanel.Dock="Top" Height="1" Background="{StaticResource BorderBrush}" Margin="0,8,0,0" />

        <!-- COLLECTIONS PANEL -->
        <Grid x:Name="CollectionsPanel">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Toolbar -->
            <Grid Grid.Row="0" Margin="8,8,8,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Style="{StaticResource GhostButton}" Click="ToggleNewForm_Click"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="+" Margin="0,0,6,0" FontSize="14" />
                        <TextBlock Text="New" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="1" Style="{StaticResource IconButton}" Click="Import_Click"
                        ToolTip="Import" Margin="6,0,0,0">
                    <Path Data="M 7 0 V 9 M 3 5 L 7 9 L 11 5 M 0 12 H 14" Stroke="{StaticResource TextSecondary}"
                          StrokeThickness="1.5" Width="14" Height="14" />
                </Button>
            </Grid>

            <!-- New collection form -->
            <Grid x:Name="NewCollectionForm" Grid.Row="1" Margin="8,4,8,4" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="NewCollectionName" Grid.Column="0" Tag="Collection name" Margin="0,0,4,0" />
                <Button Grid.Column="1" Style="{StaticResource PrimaryButton}" Click="CreateCollection_Click"
                        Padding="8,4" Margin="0,0,4,0">Create</Button>
                <Button Grid.Column="2" Style="{StaticResource GhostButton}" Click="CancelNew_Click" Padding="8,4">Cancel</Button>
            </Grid>

            <!-- Collections list -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,4,0,0">
                <ItemsControl ItemsSource="{Binding Collections}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Expander Margin="4,2" IsExpanded="False">
                                <Expander.Header>
                                    <Grid HorizontalAlignment="Stretch">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Name}" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button Style="{StaticResource IconButton}" Tag="{Binding}"
                                                    Click="ExportCollection_Click" ToolTip="Export" Padding="4">
                                                <Path Data="M 7 9 V 0 M 3 4 L 7 0 L 11 4 M 0 12 H 14" Stroke="{StaticResource TextDim}" StrokeThickness="1.5" Width="14" Height="14" />
                                            </Button>
                                            <Button Style="{StaticResource IconButton}" Tag="{Binding}"
                                                    Click="DeleteCollection_Click" ToolTip="Delete" Padding="4">
                                                <TextBlock Text="✕" FontSize="11" Foreground="{StaticResource TextDim}" />
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Expander.Header>
                                <ItemsControl ItemsSource="{Binding Requests}" Margin="22,0,4,4">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="Transparent" Padding="6,4" Margin="0,1" CornerRadius="3"
                                                    Tag="{Binding}" MouseLeftButtonUp="SavedRequest_Click" Cursor="Hand">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="Transparent" />
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#11FFFFFF" />
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding Request.Method}"
                                                               Style="{StaticResource MethodPill}"
                                                               Foreground="{Binding Request.Method, Converter={StaticResource MethodToColor}}"
                                                               Margin="0,0,8,0" />
                                                    <TextBlock Grid.Column="1" Text="{Binding Request.Url}"
                                                               TextTrimming="CharacterEllipsis" Foreground="{StaticResource TextSecondary}" FontSize="12" />
                                                    <Button Grid.Column="2" Style="{StaticResource IconButton}" Tag="{Binding}"
                                                            Click="DeleteSavedRequest_Click" Padding="2" Opacity="0.6">
                                                        <TextBlock Text="✕" FontSize="10" />
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Expander>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- HISTORY PANEL -->
        <Grid x:Name="HistoryPanel" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="8,8,8,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="HistorySearchBox" Grid.Column="0" Tag="Search history…"
                         TextChanged="HistorySearch_Changed" Margin="0,0,4,0" />
                <Button Grid.Column="1" Style="{StaticResource GhostButton}" Click="ClearHistory_Click"
                        Padding="8,4">Clear</Button>
            </Grid>

            <Border Grid.Row="1" Padding="10,4" Background="Transparent">
                <TextBlock Text="No history yet" Foreground="{StaticResource TextDim}" FontStyle="Italic">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding History.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Border>

            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding History}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="Transparent" Padding="8,6" Margin="4,1" CornerRadius="3"
                                    Tag="{Binding}" MouseLeftButtonUp="HistoryEntry_Click" Cursor="Hand">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#11FFFFFF" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Request.Method}"
                                                   Style="{StaticResource MethodPill}"
                                                   Foreground="{Binding Request.Method, Converter={StaticResource MethodToColor}}"
                                                   Margin="0,0,8,0" />
                                        <TextBlock Grid.Column="1" Text="{Binding Response.Status}"
                                                   Foreground="{Binding Response.Status, Converter={StaticResource StatusToColor}}"
                                                   FontFamily="Consolas" />
                                        <Button Grid.Column="2" Style="{StaticResource IconButton}" Tag="{Binding}"
                                                Click="OpenInNewTab_Click" ToolTip="Open in new tab" Padding="2">
                                            <TextBlock Text="↗" FontSize="11" />
                                        </Button>
                                        <Button Grid.Column="3" Style="{StaticResource IconButton}" Tag="{Binding}"
                                                Click="DeleteHistory_Click" Padding="2">
                                            <TextBlock Text="✕" FontSize="11" />
                                        </Button>
                                    </Grid>
                                    <TextBlock Grid.Row="1" Text="{Binding Request.Url}" TextTrimming="CharacterEllipsis"
                                               Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,2,0,0" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</UserControl>
