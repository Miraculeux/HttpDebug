<UserControl x:Class="HttpDebug.Views.KeyValueEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <StackPanel>
        <ItemsControl ItemsSource="{Binding Items, ElementName=Root}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" IsChecked="{Binding Enabled}" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBox Grid.Column="1" Text="{Binding Key, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Consolas" Margin="0,0,4,0" Tag="{Binding ElementName=Root, Path=KeyPlaceholder}" />
                        <TextBox Grid.Column="2" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Consolas" Margin="0,0,4,0" Tag="{Binding ElementName=Root, Path=ValuePlaceholder}" />
                        <Button Grid.Column="3" Style="{StaticResource IconButton}" Padding="6,4"
                                Click="Remove_Click" Tag="{Binding}">
                            <TextBlock Text="✕" FontSize="11" />
                        </Button>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        <Button Style="{StaticResource IconButton}" HorizontalAlignment="Left" Margin="0,4,0,0"
                Click="Add_Click">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="+" Margin="0,0,4,0" />
                <TextBlock Text="Add" />
            </StackPanel>
        </Button>
    </StackPanel>
</UserControl>
