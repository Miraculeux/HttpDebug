<UserControl x:Class="HttpDebug.Views.UrlBarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:m="clr-namespace:HttpDebug.Models"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             Background="{StaticResource Surface900}"
             DataContext="{Binding ActiveTab}">
    <UserControl.Resources>
        <ObjectDataProvider x:Key="HttpMethods" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="m:HttpMethodKind" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </UserControl.Resources>

    <Grid Margin="14,10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="110" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <ComboBox Grid.Column="0" ItemsSource="{Binding Source={StaticResource HttpMethods}}"
                  SelectedItem="{Binding Request.Method}" Margin="0,0,8,0" Height="38"
                  FontWeight="SemiBold" FontSize="13">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding}"
                               Style="{StaticResource MethodPill}"
                               Foreground="{Binding Converter={StaticResource MethodToColor}}" />
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

        <TextBox Grid.Column="1" Text="{Binding Request.Url, UpdateSourceTrigger=PropertyChanged}"
                 FontFamily="Cascadia Mono, Consolas" FontSize="14"
                 Foreground="#FF111827" Background="White"
                 Margin="0,0,8,0" Height="38" Padding="12,8"
                 Tag="https://api.example.com/endpoint"
                 KeyDown="UrlBox_KeyDown" />

        <Button Grid.Column="2" Style="{StaticResource PrimaryButton}" Click="Send_Click"
                IsEnabled="{Binding IsLoading, Converter={StaticResource InvBool}}"
                Margin="0,0,6,0" Height="38" MinWidth="90">
            <Grid>
                <TextBlock Text="Send" Visibility="{Binding IsLoading, Converter={StaticResource InvBoolToVis}}" />
                <StackPanel Orientation="Horizontal" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Sending…" />
                </StackPanel>
            </Grid>
        </Button>

        <Button Grid.Column="3" Style="{StaticResource GhostButton}" Width="38" Height="38"
                ToolTip="Save to collection" Click="SaveToCollection_Click" Margin="0,0,4,0">
            <Path Data="M 4 0 H 11 L 13 2 V 13 H 2 V 0 Z M 5 0 V 5 H 10 V 0"
                  Stroke="{StaticResource TextSecondary}" StrokeThickness="1.4" Width="14" Height="14" />
        </Button>

        <Button Grid.Column="4" Style="{StaticResource GhostButton}" Width="38" Height="38"
                ToolTip="New request (clear)" Click="Reset_Click">
            <TextBlock Text="↺" FontSize="16" Foreground="{StaticResource TextSecondary}" />
        </Button>
    </Grid>
</UserControl>
