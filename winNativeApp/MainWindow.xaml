<Window x:Class="HttpDebug.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:HttpDebug.Views"
        Title="HttpDebug"
        Width="1300" Height="820"
        MinWidth="1000" MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Icon="Assets/app.ico"
        Background="{StaticResource Surface900}">
    <Window.InputBindings>
        <KeyBinding Modifiers="Control" Key="T" Command="{Binding NewTabCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
        <KeyBinding Modifiers="Control" Key="W" Command="{Binding CloseTabCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
        <KeyBinding Modifiers="Control" Key="J" Command="{Binding ToggleSidebarCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
        <KeyBinding Modifiers="Control" Key="Return" Command="{Binding SendCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
    </Window.InputBindings>
    <DockPanel LastChildFill="True">

        <!-- Tab bar -->
        <views:TabBarView DockPanel.Dock="Top" />
        <Border DockPanel.Dock="Top" Height="1" Background="{StaticResource BorderBrush}" />

        <!-- URL bar -->
        <views:UrlBarView DockPanel.Dock="Top" />
        <Border DockPanel.Dock="Top" Height="1" Background="{StaticResource BorderBrush}" />

        <!-- Error band -->
        <Border DockPanel.Dock="Top" Padding="14,6" Background="#22F87171"
                Visibility="{Binding ActiveTab.Error, Converter={StaticResource NotNullToVis}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚠" Foreground="{StaticResource DangerBrush}" Margin="0,0,8,0" FontSize="14" />
                <TextBlock Text="{Binding ActiveTab.Error}" Foreground="{StaticResource DangerBrush}" />
            </StackPanel>
        </Border>

        <!-- Body: 3-pane split -->
        <Grid Background="{StaticResource Surface900}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidebarCol" Width="280" MinWidth="220" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" MinWidth="340" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" MinWidth="340" />
            </Grid.ColumnDefinitions>

            <views:SidebarView Grid.Column="0"
                Visibility="{Binding SidebarVisible, Converter={StaticResource BoolToVis}}" />
            <GridSplitter Grid.Column="1" Width="6"
                          Background="Transparent"
                          Visibility="{Binding SidebarVisible, Converter={StaticResource BoolToVis}}" />

            <Border Grid.Column="2" Margin="4,4,3,4"
                    Background="{StaticResource Surface950}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="6" SnapsToDevicePixels="True">
                <views:RequestView />
            </Border>
            <GridSplitter Grid.Column="3" Width="6" Background="Transparent" />
            <Border Grid.Column="4" Margin="3,4,4,4"
                    Background="{StaticResource Surface950}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="6" SnapsToDevicePixels="True">
                <views:ResponseView />
            </Border>
        </Grid>
    </DockPanel>
</Window>
